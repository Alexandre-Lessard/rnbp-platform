# RNBP Deployment Configuration
# Copy to .deploy.env and fill in your values

# SSH connection to the production server
DEPLOY_SERVER=prod@192.168.50.241

# Path to the repo on the server
DEPLOY_DIR=/opt/rnbp/repo

# Cloudflare Pages project name
CF_PROJECT=rnbp-web

# API health check URL
API_HEALTH_URL=https://api.rnbp.ca/api/health
