{
  "name": "@rnbp/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node --env-file=.env dist/index.js",
    "migrate": "node --env-file=.env dist/migrate.js",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@rnbp/shared": "workspace:*",
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "file-type": "^21.3.0",
    "jose": "^6.1.3",
    "nanoid": "^5.1.6",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
