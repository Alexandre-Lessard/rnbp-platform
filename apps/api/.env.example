# Database
DATABASE_URL=postgresql://rnbp:password@localhost:5432/rnbp

# JWT (Ed25519 keys, base64-encoded)
# Generate with: openssl genpkey -algorithm Ed25519 -out private.pem && openssl pkey -in private.pem -pubout -out public.pem
# Then base64 encode: base64 -w0 private.pem && base64 -w0 public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Cloudflare R2 (optional — leave empty to disable file uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rnbp-uploads
R2_PUBLIC_URL=

# Email (Brevo)
BREVO_API_KEY=
FROM_EMAIL=noreply@rnbp.ca
FROM_NAME=RNBP

# OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Admin notifications
ADMIN_ORDER_EMAIL=
ADMIN_CONTACT_EMAIL=

# Stripe (product prices are stored in the products DB table, not here)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
