{
  "name": "rcbp",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @rcbp/web dev",
    "dev:api": "pnpm --filter @rcbp/api dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @rcbp/web build",
    "build:api": "pnpm --filter @rcbp/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "onlyBuiltDependencies": [
    "argon2",
    "esbuild",
    "sharp",
    "workerd"
  ]
}