{
  "name": "rnbp",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @rnbp/web dev",
    "dev:api": "pnpm --filter @rnbp/api dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @rnbp/web build",
    "build:api": "pnpm --filter @rnbp/api build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "deploy": "./ops/deploy.sh",
    "deploy:web": "./ops/deploy.sh web",
    "deploy:api": "./ops/deploy.sh api",
    "rollback": "./ops/rollback.sh"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}